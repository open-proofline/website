---
import { site } from "../../site.config.mjs";

const year = new Date().getFullYear();

const links = [
  { href: "/about/", label: "About" },
  { href: "/status/", label: "Status" },
  { href: "/services/", label: "Community services" },
  { href: "/support/", label: "Support" },
  {
    href: "https://github.com/open-proofline/website/blob/main/SECURITY.md",
    label: "Security policy",
  },
  { href: site.sourceCode, label: "Source code" },
  { href: site.githubOrg, label: "GitHub" },
];
---

<footer class="border-t border-proofline-border bg-proofline-bg-deep/80">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-6 text-sm leading-6 text-proofline-text-muted sm:px-6 lg:flex-row lg:items-start lg:justify-between"
  >
    <div>
      <p class="font-medium text-proofline-text">Proofline</p>
      <p class="mt-1 max-w-2xl">
        Experimental encrypted incident-capture project. Proofline is not an
        emergency service, and users and trusted contacts remain responsible for
        contacting emergency services.
      </p>
      <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2">
        {
          links.map((link) => (
            <a
              href={link.href}
              class="rounded-md text-proofline-accent-cyan underline underline-offset-4 hover:text-proofline-primary-hover focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
    <p class="shrink-0">
      © {year} Proofline contributors. License:
      <a
        href={site.licenseUrl}
        class="rounded-md text-proofline-accent-cyan underline underline-offset-4 hover:text-proofline-primary-hover focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
      >
        {site.license}
      </a>
    </p>
  </div>
</footer>
