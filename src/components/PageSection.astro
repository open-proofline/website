---
type Props = {
  eyebrow?: string;
  title?: string;
};

const { eyebrow, title } = Astro.props;
---

<section
  class="scroll-mt-28 min-w-0 rounded-lg border border-proofline-border bg-proofline-surface p-5 pt-6 shadow-lg shadow-proofline-bg-deep/20 sm:p-6 sm:pt-7 lg:scroll-mt-32 lg:p-7 lg:pt-8"
>
  {
    eyebrow || title ? (
      <div class="mb-4">
        {eyebrow ? (
          <p class="text-sm font-medium text-proofline-accent-cyan">
            {eyebrow}
          </p>
        ) : null}
        {title ? (
          <h2 class="mt-1 text-xl font-semibold tracking-normal text-proofline-text">
            {title}
          </h2>
        ) : null}
      </div>
    ) : null
  }
  <slot />
</section>
