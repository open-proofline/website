---
import Icon from "./Icon.astro";
import { site } from "../../site.config.mjs";

type IconName =
  | "home"
  | "info"
  | "activity"
  | "shield"
  | "code"
  | "route"
  | "lock"
  | "globe"
  | "heart"
  | "repo"
  | "github";

type NavItem = {
  href: string;
  label: string;
  icon?: IconName;
  external?: boolean;
  ariaLabel?: string;
};

type NavGroup = {
  label: string;
  icon: IconName;
  items: readonly NavItem[];
};

const desktopPrimaryLinks: readonly NavItem[] = [
  { href: "/", label: "Home", icon: "home" },
  { href: "/status/", label: "Status", icon: "activity" },
  { href: "/services/", label: "Community services", icon: "globe" },
  { href: "/about/", label: "About", icon: "info" },
] as const;

const desktopGroups: readonly NavGroup[] = [
  {
    label: "Project",
    icon: "code",
    items: [
      { href: "/repositories/", label: "Repositories", icon: "repo" },
      { href: "/open-source/", label: "Open source", icon: "code" },
      { href: "/roadmap/", label: "Roadmap", icon: "route" },
      { href: "/safety/", label: "Safety boundaries", icon: "shield" },
      { href: "/security/", label: "Security", icon: "lock" },
    ],
  },
] as const;

const desktopUtilityLinks: readonly NavItem[] = [
  { href: "/support/", label: "Support", icon: "heart" },
  {
    href: site.githubOrg,
    label: "GitHub",
    icon: "github",
    external: true,
    ariaLabel: "Open Proofline on GitHub",
  },
] as const;

const mobileGroups: readonly { label: string; items: readonly NavItem[] }[] = [
  {
    label: "Main",
    items: [
      { href: "/", label: "Home", icon: "home" },
      { href: "/status/", label: "Current status", icon: "activity" },
      { href: "/services/", label: "Community services", icon: "globe" },
      { href: "/about/", label: "About Proofline", icon: "info" },
    ],
  },
  {
    label: "Project",
    items: [
      { href: "/repositories/", label: "Repositories", icon: "repo" },
      { href: "/open-source/", label: "Open source", icon: "code" },
      { href: "/roadmap/", label: "Roadmap", icon: "route" },
      { href: "/safety/", label: "Safety boundaries", icon: "shield" },
      { href: "/security/", label: "Security", icon: "lock" },
      {
        href: site.githubOrg,
        label: "GitHub",
        icon: "github",
        external: true,
        ariaLabel: "Open Proofline on GitHub",
      },
    ],
  },
  {
    label: "Support",
    items: [{ href: "/support/", label: "Support Proofline", icon: "heart" }],
  },
] as const;

const currentPath = Astro.url.pathname;

function isCurrentPage(href: string, external = false) {
  if (external) return false;

  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath === href || currentPath.startsWith(href);
}

function isGroupActive(group: NavGroup) {
  return group.items.some((item) => isCurrentPage(item.href, item.external));
}

function groupId(label: string) {
  return `desktop-nav-${label.toLowerCase().replaceAll(" ", "-")}`;
}
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-proofline-border/70 bg-proofline-bg/90 shadow-[0_16px_60px_rgba(0,0,0,0.35)] backdrop-blur-2xl xl:border-b-0 xl:bg-transparent xl:px-4 xl:py-3 xl:shadow-none xl:backdrop-blur-none"
>
  <div
    class="flex w-full items-center justify-between gap-3 px-4 py-3 xl:mx-auto xl:max-w-6xl xl:rounded-full xl:border xl:border-proofline-border/70 xl:bg-proofline-bg/80 xl:px-3 xl:py-2 xl:shadow-[0_20px_70px_rgba(0,0,0,0.35)] xl:backdrop-blur-2xl"
  >
    <a
      href="/"
      class="inline-flex min-w-0 max-w-full items-center gap-3 rounded-md focus:outline-2 focus:outline-offset-4 focus:outline-proofline-focus"
      aria-label="Proofline home"
    >
      <img
        src="/proofline-shield-logo.svg"
        alt=""
        aria-hidden="true"
        class="size-10 shrink-0 object-contain sm:size-11"
      />
      <span class="min-w-0">
        <span class="flex min-w-0 items-center gap-2">
          <span
            class="truncate text-lg font-semibold leading-6 text-proofline-text"
          >
            Proofline
          </span>
          <span
            class="shrink-0 rounded-full border border-proofline-warning/40 bg-proofline-warning-bg px-2 py-0.5 text-xs font-medium leading-4 text-proofline-warning max-[340px]:hidden"
          >
            Experimental
          </span>
        </span>
      </span>
    </a>

    <nav aria-label="Primary" class="hidden min-w-0 xl:block">
      <ul class="flex min-w-0 items-center justify-end gap-1">
        {
          desktopPrimaryLinks.map((item) => {
            const active = isCurrentPage(item.href, item.external);

            return (
              <li>
                <a
                  href={item.href}
                  aria-label={item.ariaLabel}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "inline-flex h-9 items-center gap-1.5 whitespace-nowrap rounded-md border text-sm font-medium leading-none transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus",
                    active
                      ? "border-proofline-border-strong bg-proofline-surface-strong text-proofline-text shadow-sm shadow-proofline-bg-deep/30"
                      : "border-transparent text-proofline-text-muted hover:bg-proofline-surface-elevated hover:text-proofline-text",
                    item.external ? "px-2.5" : "px-2.5 2xl:px-3",
                  ]}
                >
                  {item.icon ? (
                    <Icon
                      name={item.icon}
                      class={`shrink-0 self-center ${item.icon === "github" ? "size-[17px]" : "size-4"}`}
                    />
                  ) : null}
                  {item.external ? (
                    <span class="sr-only">{item.label}</span>
                  ) : (
                    item.label
                  )}
                </a>
              </li>
            );
          })
        }
        {
          desktopGroups.map((group) => {
            const active = isGroupActive(group);
            const id = groupId(group.label);

            return (
              <li class="relative">
                <details class="group" data-nav-details>
                  <summary
                    id={`${id}-trigger`}
                    aria-controls={`${id}-menu`}
                    aria-current={active ? "page" : undefined}
                    aria-expanded="false"
                    data-nav-summary
                    class:list={[
                      "inline-flex h-9 cursor-pointer list-none items-center gap-1.5 whitespace-nowrap rounded-md border px-2.5 text-sm font-medium leading-none transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus 2xl:px-3 [&::-webkit-details-marker]:hidden",
                      active
                        ? "border-proofline-border-strong bg-proofline-surface-strong text-proofline-text shadow-sm shadow-proofline-bg-deep/30"
                        : "border-transparent text-proofline-text-muted hover:bg-proofline-surface-elevated hover:text-proofline-text group-open:border-proofline-border group-open:bg-proofline-surface-elevated group-open:text-proofline-text",
                    ]}
                  >
                    <Icon
                      name={group.icon}
                      class="size-4 shrink-0 self-center"
                    />
                    <span>{group.label}</span>
                    <Icon
                      name="chevron-down"
                      class="size-3.5 shrink-0 self-center transition-transform group-open:rotate-180"
                    />
                  </summary>
                  <div
                    id={`${id}-menu`}
                    aria-labelledby={`${id}-trigger`}
                    class="absolute left-0 top-full z-30 mt-3 w-60 overflow-hidden rounded-xl border border-proofline-border/80 bg-proofline-bg shadow-[0_24px_80px_rgba(0,0,0,0.5)]"
                  >
                    <ul class="relative grid gap-1 p-2">
                      {group.items.map((item) => {
                        const itemActive = isCurrentPage(
                          item.href,
                          item.external,
                        );

                        return (
                          <li>
                            <a
                              href={item.href}
                              aria-current={itemActive ? "page" : undefined}
                              class:list={[
                                "flex min-h-10 min-w-0 items-center gap-2 rounded-md border px-3 text-sm font-medium focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus",
                                itemActive
                                  ? "border-proofline-border-strong bg-proofline-surface-strong text-proofline-text"
                                  : "border-transparent text-proofline-text-muted hover:bg-proofline-surface-elevated hover:text-proofline-text",
                              ]}
                            >
                              {item.icon ? (
                                <Icon
                                  name={item.icon}
                                  class="size-4 shrink-0 self-center"
                                />
                              ) : null}
                              <span class="min-w-0 truncate">{item.label}</span>
                            </a>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                </details>
              </li>
            );
          })
        }
        {
          desktopUtilityLinks.map((item) => {
            const active = isCurrentPage(item.href, item.external);

            return (
              <li>
                <a
                  href={item.href}
                  aria-label={item.ariaLabel}
                  aria-current={active ? "page" : undefined}
                  class:list={[
                    "inline-flex h-9 items-center gap-1.5 whitespace-nowrap rounded-md border px-2.5 text-sm font-medium leading-none transition-colors focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus 2xl:px-3",
                    active
                      ? "border-proofline-border-strong bg-proofline-surface-strong text-proofline-text shadow-sm shadow-proofline-bg-deep/30"
                      : "border-transparent text-proofline-text-muted hover:bg-proofline-surface-elevated hover:text-proofline-text",
                  ]}
                >
                  {item.icon ? (
                    <Icon
                      name={item.icon}
                      class={`shrink-0 self-center ${item.icon === "github" ? "size-[17px]" : "size-4"}`}
                    />
                  ) : null}
                  <span>{item.label}</span>
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <details
      class="group relative xl:hidden"
      data-mobile-nav-details
      data-nav-details
    >
      <summary
        aria-controls="primary-mobile-navigation"
        aria-expanded="false"
        data-nav-summary
        class="flex size-11 cursor-pointer list-none items-center justify-center rounded-md border border-proofline-border bg-proofline-bg/90 text-proofline-text shadow-sm shadow-proofline-bg/40 backdrop-blur-2xl hover:bg-proofline-surface-elevated focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus [&::-webkit-details-marker]:hidden"
      >
        <span class="sr-only group-open:hidden">Open navigation</span>
        <span class="sr-only hidden group-open:inline">Close navigation</span>
        <Icon name="menu" class="size-5 group-open:hidden" />
        <Icon name="x" class="hidden size-5 group-open:block" />
      </summary>
      <nav
        id="primary-mobile-navigation"
        aria-label="Primary menu"
        class="absolute right-0 top-14 z-20 max-h-[calc(100vh-6rem)] w-[min(23rem,calc(100vw-2rem))] overflow-hidden rounded-xl border border-proofline-border/80 bg-proofline-bg shadow-[0_24px_80px_rgba(0,0,0,0.5)] sm:max-h-[34rem]"
      >
        <div
          class="relative grid max-h-[calc(100vh-6rem)] gap-4 overflow-y-auto overscroll-contain p-3 sm:max-h-[34rem]"
        >
          {
            mobileGroups.map((group) => (
              <section
                aria-labelledby={`mobile-nav-${group.label.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}`}
                class="border-t border-proofline-border/70 pt-3 first:border-t-0 first:pt-0"
              >
                <p
                  id={`mobile-nav-${group.label.toLowerCase().replaceAll(" ", "-").replaceAll("&", "and")}`}
                  class="px-2 text-xs font-semibold uppercase tracking-normal text-proofline-text-subtle"
                >
                  {group.label}
                </p>
                <ul class="mt-1 grid gap-1">
                  {group.items.map((item) => {
                    const active = isCurrentPage(item.href, item.external);

                    return (
                      <li>
                        <a
                          href={item.href}
                          aria-label={item.ariaLabel}
                          aria-current={active ? "page" : undefined}
                          class:list={[
                            "flex min-h-11 min-w-0 items-center gap-3 rounded-md border px-3 text-sm font-medium focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus",
                            active
                              ? "border-proofline-border-strong bg-proofline-surface-strong text-proofline-text"
                              : "border-transparent text-proofline-text-muted hover:bg-proofline-surface-elevated hover:text-proofline-text",
                          ]}
                        >
                          {item.icon ? (
                            <Icon
                              name={item.icon}
                              class={`shrink-0 self-center ${item.icon === "github" ? "size-[17px]" : "size-4"}`}
                            />
                          ) : null}
                          <span class="min-w-0 break-words">{item.label}</span>
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </section>
            ))
          }
        </div>
      </nav>
    </details>
  </div>
</header>

<script is:inline src="/site-js/mobile-nav.js" defer></script>
