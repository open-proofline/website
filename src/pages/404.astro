---
import PageSection from "../components/PageSection.astro";
import SourceLink from "../components/SourceLink.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import { site } from "../../site.config.mjs";
---

<ContentLayout
  title="Page Not Found"
  eyebrow="404"
  description="The requested Proofline website page could not be found. It may have moved, been renamed, or fallen into a documentation crevice."
>
  <PageSection title="Page not found">
    <p class="max-w-3xl leading-7 text-proofline-text-secondary">
      The page may have moved, been renamed, or fallen into a documentation
      crevice. Return to <SourceLink href="/">Proofline home</SourceLink>,
      review <SourceLink href="/status/">current status</SourceLink>, or check
      the <SourceLink href={site.githubOrg}>GitHub organization</SourceLink>
      for source documents.
    </p>
  </PageSection>
</ContentLayout>
