---
import ClaimCard from "../components/ClaimCard.astro";
import PageSection from "../components/PageSection.astro";
import SourceLink from "../components/SourceLink.astro";
import SourceList from "../components/SourceList.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import { site } from "../../site.config.mjs";

const sources = [
  {
    label: "Organization profile repositories",
    href: "https://github.com/open-proofline/.github/blob/main/profile/README.md#current-status",
  },
  {
    label: "Server AGENTS",
    href: "https://github.com/open-proofline/server/blob/develop/AGENTS.md",
  },
  {
    label: "Server README",
    href: "https://github.com/open-proofline/server/blob/develop/README.md",
  },
  {
    label: "Web-client AGENTS",
    href: "https://github.com/open-proofline/web-client/blob/develop/AGENTS.md",
  },
  {
    label: "Web-client README",
    href: "https://github.com/open-proofline/web-client/blob/develop/README.md",
  },
];
---

<ContentLayout
  title="Repositories"
  eyebrow="Current and planned repository split"
  description="Proofline is split by component. The server and web client exist today; iOS, Android, and protocol repositories are planned."
>
  <div class="grid gap-4 md:grid-cols-2">
    <ClaimCard label="Current" tone="success" title="open-proofline/server">
      Go backend for authenticated main API routes, local account/session auth,
      second-factor gates, private admin surfaces, read-only viewer, encrypted
      chunk ingest, owner and trusted-contact metadata, wrapped-key metadata,
      deletion and retention workflows, quotas, optional
      PostgreSQL/S3-compatible/Valkey backends, experimental relay primitives,
      releases, deployment docs, and backend reference documentation.
      <p class="mt-3">
        <SourceLink href={site.repositories.server}
          >Open server repository</SourceLink
        >
      </p>
    </ClaimCard>
    <ClaimCard label="Current" tone="success" title="open-proofline/web-client">
      React account portal and incident-review prototype for account UI,
      login/logout, registration and email-verification flows, conservative
      browser session handling, mock/live API modes, incident metadata review,
      contact and sharing-grant metadata views, and wrapped-key metadata views.
      <p class="mt-3">
        <SourceLink href={site.repositories.webClient}
          >Open web-client repository</SourceLink
        >
      </p>
    </ClaimCard>
    <ClaimCard label="Planned" tone="info" title="open-proofline/ios-client">
      Future native iOS incident capture, encrypted local staging, upload, local
      account flows, and platform-specific recording behavior.
    </ClaimCard>
    <ClaimCard
      label="Planned"
      tone="info"
      title="open-proofline/android-client"
    >
      Future native Android incident capture, encrypted local staging, upload,
      local account flows, and platform-specific recording behavior.
    </ClaimCard>
    <ClaimCard label="Planned" tone="info" title="open-proofline/protocol">
      Future shared API specs, encryption envelope specs, bundle manifests,
      compatibility matrix, and conformance tests.
    </ClaimCard>
    <ClaimCard label="Scope" tone="warning" title="Separate components">
      Server, web-client, mobile client, and protocol work are kept in separate
      repositories so each component has a clear home.
    </ClaimCard>
  </div>

  <PageSection title="Project docs">
    <p class="max-w-3xl text-sm leading-6 text-proofline-text-secondary">
      The repository docs linked below provide the detailed implementation and
      security context behind this website’s shorter overview.
    </p>
  </PageSection>

  <SourceList sources={sources} />
</ContentLayout>
