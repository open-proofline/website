---
import ClaimCard from "../components/ClaimCard.astro";
import Icon from "../components/Icon.astro";
import PageSection from "../components/PageSection.astro";
import SourceLink from "../components/SourceLink.astro";
import SourceList from "../components/SourceList.astro";
import ContentLayout from "../layouts/ContentLayout.astro";

const redlibUrl = "https://redlib.proofline.live";
const statusPageUrl = "https://status.proofline.live";

const sources = [
  {
    label: "Proofline Redlib fork",
    href: "https://github.com/open-proofline/redlib",
  },
  {
    label: "Redlib upstream repository",
    href: "https://github.com/redlib-org/redlib",
  },
  {
    label: "Organization profile funding reality",
    href: "https://github.com/open-proofline/.github/blob/main/profile/README.md#maintainer-and-funding-reality",
  },
  {
    label: "Current status",
    href: "/status/",
  },
];
---

<ContentLayout
  title="Community services"
  eyebrow="Active lightweight open-source tools"
  description="Community services are best-effort public tools operated separately from Proofline's safety, evidence, account, and emergency boundaries."
>
  <a
    slot="heroActions"
    href={statusPageUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-proofline-border-strong bg-proofline-primary px-4 py-3 text-sm font-semibold text-proofline-primary-text shadow-lg shadow-proofline-bg-deep/30 transition-colors hover:bg-proofline-primary-hover focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
  >
    <Icon name="arrow-up-right" class="size-4" />
    <span>Check service status</span>
  </a>
  <p
    slot="heroActions"
    class="basis-full text-sm leading-6 text-proofline-text-muted"
  >
    Live service status and planned maintenance notices are available on the
    Proofline status page.
  </p>

  <PageSection title="Active services">
    <div class="grid gap-4 md:grid-cols-2">
      <ClaimCard label="Active" tone="success" title="Redlib">
        <p>
          A privacy-friendly Reddit frontend operated as a Proofline community
          service.
        </p>
        <p class="mt-3">
          Hosted on Proofline-operated dedicated hardware in Victoria,
          Australia.
        </p>
        <p class="mt-3">
          Redlib may present a brief anti-abuse challenge to protect service
          availability and reduce automated scraping.
        </p>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:flex-wrap">
          <a
            href={redlibUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-11 items-center justify-center gap-2 rounded-md border border-proofline-border-strong bg-proofline-primary px-4 py-2.5 text-sm font-semibold text-proofline-primary-text shadow-lg shadow-proofline-bg-deep/30 transition-colors hover:bg-proofline-primary-hover focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
          >
            <Icon name="globe" class="size-4" />
            <span>Open Redlib</span>
          </a>
          <a
            href={statusPageUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-11 items-center justify-center gap-2 rounded-md border border-proofline-border-strong bg-proofline-surface-strong/90 px-4 py-2.5 text-sm font-semibold text-proofline-text shadow-lg shadow-proofline-bg-deep/30 transition-colors hover:bg-proofline-border focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
          >
            <Icon name="arrow-up-right" class="size-4" />
            <span>Check status</span>
          </a>
        </div>
        <p class="mt-4">
          <SourceLink href="https://github.com/open-proofline/redlib">
            Open Proofline Redlib fork
          </SourceLink>
        </p>
        <p class="mt-2">
          <SourceLink href="https://github.com/redlib-org/redlib">
            Open Redlib upstream repository
          </SourceLink>
        </p>
      </ClaimCard>
    </div>
  </PageSection>

  <PageSection title="Service boundaries">
    <div class="grid gap-3 text-sm leading-6 text-proofline-text-secondary">
      <p>
        Community services are operated separately from Proofline Server and are
        not part of Proofline's safety, evidence, account, or emergency
        workflows.
      </p>
      <p>
        Proofline community services are provided on a best-effort basis. They
        may be updated, restarted, rate-limited, or temporarily unavailable
        during maintenance or abuse mitigation.
      </p>
      <ul class="grid gap-2 md:grid-cols-3">
        <li>They do not guarantee uptime, availability, or an SLA.</li>
        <li>They are not emergency infrastructure or support channels.</li>
        <li>
          They do not store Proofline evidence, account data, or safety records.
        </li>
      </ul>
    </div>
  </PageSection>

  <PageSection title="Future services">
    <p class="max-w-3xl text-sm leading-6 text-proofline-text-secondary">
      Additional lightweight open-source services may be considered later. Any
      future listing should stay clearly separate from Proofline itself.
    </p>
  </PageSection>

  <SourceList sources={sources} />
</ContentLayout>
