---
import ClaimCard from "../components/ClaimCard.astro";
import PageSection from "../components/PageSection.astro";
import SourceLink from "../components/SourceLink.astro";
import SourceList from "../components/SourceList.astro";
import ContentLayout from "../layouts/ContentLayout.astro";

const sources = [
  {
    label: "Redlib upstream repository",
    href: "https://github.com/redlib-org/redlib",
  },
  {
    label: "Organization profile funding reality",
    href: "https://github.com/open-proofline/.github/blob/main/profile/README.md#maintainer-and-funding-reality",
  },
  {
    label: "Current status",
    href: "/status/",
  },
];
---

<ContentLayout
  title="Community services"
  eyebrow="Planned lightweight open-source tools"
  description="Community services are best-effort public tools operated separately from Proofline's safety, evidence, account, and emergency boundaries."
>
  <PageSection title="Planned services">
    <div class="grid gap-4 md:grid-cols-2">
      <ClaimCard label="Planned" tone="info" title="Redlib">
        <p>
          Redlib is planned as a separate best-effort community service. It is a
          lightweight private front end for browsing Reddit, not part of
          Proofline's safety model.
        </p>
        <p class="mt-3">
          The upstream Redlib project describes itself as an alternative private
          front end to Reddit focused on lighter, more private browsing.
        </p>
        <p class="mt-3">Service URL: to be added later.</p>
        <p class="mt-3">
          <SourceLink href="https://github.com/redlib-org/redlib">
            Open Redlib upstream repository
          </SourceLink>
        </p>
      </ClaimCard>
    </div>
  </PageSection>

  <PageSection title="Service boundaries">
    <div class="grid gap-4 md:grid-cols-2">
      <ClaimCard label="Separate" tone="warning" title="Not core Proofline">
        Community services are separate from Proofline's incident-capture,
        evidence-preservation, account, and safety-context systems.
      </ClaimCard>
      <ClaimCard
        label="Best effort"
        tone="warning"
        title="No availability promise"
      >
        These services may change, move, pause, or go offline while the project
        is early. They are not a status page, support commitment, or
        service-level agreement.
      </ClaimCard>
      <ClaimCard
        label="Safety"
        tone="danger"
        title="Not emergency infrastructure"
      >
        Do not use community services for urgent safety needs. They do not
        provide emergency dispatch, incident response, account recovery, or
        guaranteed real-time availability.
      </ClaimCard>
      <ClaimCard
        label="Data boundary"
        tone="danger"
        title="No Proofline evidence"
      >
        Community services do not store Proofline evidence, encrypted chunks,
        incident records, wrapped keys, account data, or safety-context records.
      </ClaimCard>
    </div>
  </PageSection>

  <PageSection title="Future services">
    <p class="max-w-3xl text-sm leading-6 text-proofline-text-secondary">
      Additional lightweight open-source services may be considered later. Any
      future listing should stay clearly separate from Proofline's safety,
      evidence-capture, account, and hosted-service direction.
    </p>
  </PageSection>

  <SourceList sources={sources} />
</ContentLayout>
