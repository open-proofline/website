---
import ClaimCard from "../components/ClaimCard.astro";
import PageSection from "../components/PageSection.astro";
import SourceList from "../components/SourceList.astro";
import ContentLayout from "../layouts/ContentLayout.astro";

const sources = [
  {
    label: "Organization profile current status",
    href: "https://github.com/open-proofline/.github/blob/main/profile/README.md#current-status",
  },
  {
    label: "Server README",
    href: "https://github.com/open-proofline/server/blob/develop/README.md",
  },
  {
    label: "Server API documentation",
    href: "https://github.com/open-proofline/server/blob/develop/docs/api.md",
  },
  {
    label: "Server security model",
    href: "https://github.com/open-proofline/server/blob/develop/docs/security-model.md",
  },
  {
    label: "Contact key sharing and grants",
    href: "https://github.com/open-proofline/server/blob/develop/docs/contact-key-sharing-grants.md",
  },
  {
    label: "Regional stream ingress relay",
    href: "https://github.com/open-proofline/server/blob/develop/docs/regional-stream-ingress-relay.md",
  },
  {
    label: "Web-client README",
    href: "https://github.com/open-proofline/web-client/blob/develop/README.md",
  },
];
---

<ContentLayout
  title="Current status"
  eyebrow="Implemented, partial, planned, and not yet"
  description="Proofline has experimental server and web-client prototypes. Mobile capture, hosted accounts, notifications, and decryption are not production features."
>
  <PageSection title="Implemented today">
    <ul
      class="grid gap-3 text-sm leading-6 text-proofline-text-secondary md:grid-cols-2"
    >
      <li>Experimental Go server backend for authenticated main API routes.</li>
      <li>
        Experimental React web-client prototype for account and incident review.
      </li>
      <li>
        Local username/password accounts, opaque server-side sessions, and
        optional browser cookie-session support with CSRF checks and
        exact-origin CORS for future web-client use.
      </li>
      <li>
        Public registration is disabled by default. Open self-registration only
        works when a deployment explicitly enables SMTP-backed email
        verification.
      </li>
      <li>
        Email challenge, TOTP, and disabled-by-default WebAuthn/FIDO2
        second-factor setup for account gating.
      </li>
      <li>
        Private admin listener and private admin web surface with admin
        second-factor gates and private-admin assisted lost-factor reset.
      </li>
      <li>Read-only token-scoped incident viewer routes.</li>
      <li>
        Encrypted chunk ingest, immutable storage, and ciphertext hash checks.
      </li>
      <li>
        SQLite/local storage defaults with optional PostgreSQL, S3-compatible,
        and Valkey backends.
      </li>
      <li>
        Default local staging quota, account-scoped committed blob quota, and
        app-level route-class rate limits.
      </li>
      <li>
        Server-side incident metadata, owner-scoped read routes, and
        deletion/retention workflows.
      </li>
      <li>
        Owner-scoped account/device recipient-key metadata, trusted-contact
        relationships, contact public-key metadata, sharing grants, and
        wrapped-key metadata routes.
      </li>
      <li>
        Signed-in trusted-contact wrapped-key metadata reads when an accepted
        relationship, active key, active grant, and active wrapped-key record
        all authorize the request.
      </li>
      <li>
        Experimental stream-ingress relay primitives for complete encrypted
        chunk upload and optimistic encrypted fanout, with core backend
        confirmation still authoritative.
      </li>
    </ul>
  </PageSection>

  <div class="grid gap-4 md:grid-cols-2">
    <ClaimCard
      label="Experimental / partial"
      tone="warning"
      title="Registration"
    >
      Open registration can be enabled only with reviewed server configuration
      and email verification. Paid registration is a fail-closed placeholder,
      not billing.
    </ClaimCard>
    <ClaimCard
      label="Experimental / partial"
      tone="warning"
      title="Sharing metadata"
    >
      Contact keys, trusted-contact relationships, sharing grants, and
      wrapped-key records exist as authenticated API metadata. They do not add
      trusted-contact incident review, notifications, browser decryption,
      backend decryption, production key custody, or key escrow.
    </ClaimCard>
    <ClaimCard
      label="Experimental / partial"
      tone="warning"
      title="Live API testing"
    >
      The web client can model account and incident review surfaces and uses
      live backend routes only where the client contract is confirmed. It is not
      a recording client, public admin dashboard, or production safety workflow.
    </ClaimCard>
    <ClaimCard
      label="Experimental / partial"
      tone="warning"
      title="Cluster backends"
    >
      PostgreSQL, S3-compatible storage, and Valkey are optional implemented
      backends. They do not make Proofline public-production-ready by
      themselves.
    </ClaimCard>
    <ClaimCard
      label="Experimental / partial"
      tone="warning"
      title="Stream-ingress relay"
    >
      Relay upload and fanout primitives exist for complete encrypted chunks.
      Relay replay, metrics, production service-identity rotation, durable relay
      storage, and production deployment hardening are not implemented.
    </ClaimCard>
  </div>

  <PageSection title="Planned future work">
    <ul
      class="grid gap-3 text-sm leading-6 text-proofline-text-secondary md:grid-cols-2"
    >
      <li>Native iOS and Android recording clients.</li>
      <li>GPS/location capture and live context sharing where available.</li>
      <li>
        Production-ready regional ingest, relay replay, resumable or partial
        upload protocols, and stronger client retry behavior.
      </li>
      <li>SMS, email, push, or other trusted-contact notification delivery.</li>
      <li>
        Production trusted-contact UX and grant-aware incident review workflows.
      </li>
      <li>
        Hosted accounts, subscriptions, billing, abuse controls, and support
        operations.
      </li>
      <li>
        Shared protocol specs, encryption envelopes, manifests, and conformance
        tests.
      </li>
      <li>
        Reviewed browser/client-side decryption or other trusted decrypt path.
      </li>
    </ul>
  </PageSection>

  <div class="grid gap-4 md:grid-cols-2">
    <ClaimCard
      label="Not yet"
      tone="danger"
      title="No production emergency workflow"
    >
      No emergency-services integration, dispatch, guaranteed real-time review,
      rescue workflow, or emergency response center exists.
    </ClaimCard>
    <ClaimCard
      label="Not yet"
      tone="danger"
      title="No production decryption path"
    >
      No browser decryption, backend decryption, trusted-contact decryption, raw
      server-held media keys, key escrow, or break-glass key access is
      implemented.
    </ClaimCard>
    <ClaimCard label="Not yet" tone="danger" title="No mobile capture apps">
      There is no production iOS app, Android app, or platform-specific
      recording client.
    </ClaimCard>
    <ClaimCard
      label="Not yet"
      tone="danger"
      title="No hosted-account payment system"
    >
      There are no checkout sessions, subscriptions, billing webhooks,
      payment-gated account access, or active paid account creation.
    </ClaimCard>
  </div>

  <SourceList sources={sources} />
</ContentLayout>
