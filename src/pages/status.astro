---
import ClaimCard from "../components/ClaimCard.astro";
import PageSection from "../components/PageSection.astro";
import SourceLink from "../components/SourceLink.astro";
import SourceList from "../components/SourceList.astro";
import ContentLayout from "../layouts/ContentLayout.astro";
import { site } from "../../site.config.mjs";

const sources = [
  {
    label: "Organization profile current status",
    href: "https://github.com/open-proofline/.github/blob/main/profile/README.md#current-status",
  },
  {
    label: "Server README",
    href: "https://github.com/open-proofline/server/blob/develop/README.md",
  },
  {
    label: "Server security model",
    href: "https://github.com/open-proofline/server/blob/develop/docs/security-model.md",
  },
  {
    label: "Web-client README",
    href: "https://github.com/open-proofline/web-client/blob/develop/README.md",
  },
];
---

<ContentLayout
  title="Current status"
  eyebrow="What exists, what is partial, and what is not ready"
  description="Proofline has experimental server and web-client work today. Production capture clients, hosted accounts, notifications, and decryption workflows are not ready."
  safetyMode="full"
>
  <div class="grid gap-4 md:grid-cols-2">
    <ClaimCard label="Current" tone="success" title="Experimental server">
      The server can handle authenticated account routes, receive
      already-encrypted evidence chunks, store metadata, enforce quotas and rate
      limits, and support private operator workflows.
    </ClaimCard>
    <ClaimCard label="Current" tone="success" title="Web-client prototype">
      The web client is an experimental account and incident-review prototype.
      It is not a recording client, mobile app, public admin dashboard, or
      production safety workflow.
    </ClaimCard>
    <ClaimCard label="Partial" tone="warning" title="Trusted-contact metadata">
      Trusted-contact relationships, sharing grants, and wrapped-key metadata
      exist as authenticated backend data. They do not yet add production
      trusted-contact review, notification delivery, or decryption.
    </ClaimCard>
    <ClaimCard label="Partial" tone="warning" title="Deployment hardening">
      Optional PostgreSQL, S3-compatible storage, Valkey coordination, and relay
      primitives exist, but they do not make Proofline public-production
      infrastructure by themselves.
    </ClaimCard>
    <ClaimCard label="Planned" tone="info" title="Product direction">
      Native capture clients, location and context capture, trusted-contact
      review, hosted accounts, billing, and stronger upload behavior are future
      work.
    </ClaimCard>
    <ClaimCard label="Not ready" tone="danger" title="Emergency reliance">
      There is no emergency-services integration, dispatch, staffed monitoring,
      guaranteed real-time response, or production mobile recording workflow.
    </ClaimCard>
  </div>

  <PageSection title="Not implemented today">
    <ul
      class="grid gap-3 text-sm leading-6 text-proofline-text-secondary md:grid-cols-2"
    >
      <li>Production iOS or Android capture clients.</li>
      <li>Trusted-contact SMS, email, push, or Messenger notifications.</li>
      <li>Live location/context sharing as a production feature.</li>
      <li>Browser, backend, or trusted-contact decryption workflows.</li>
      <li>Raw server-held media keys, key escrow, or break-glass access.</li>
      <li>
        Hosted-account billing, checkout, or active paid account creation.
      </li>
      <li>Playable media export or legal-submission workflow.</li>
      <li>Public production deployment hardening for broad API exposure.</li>
    </ul>
  </PageSection>

  <PageSection title="Where detailed docs live">
    <p class="max-w-3xl text-sm leading-6 text-proofline-text-secondary">
      The public website is intentionally short. Developers and reviewers should
      use the GitHub repositories for implementation details, deployment
      boundaries, security models, and roadmap planning:
      <SourceLink href={site.githubOrg}>open-proofline on GitHub</SourceLink>.
    </p>
  </PageSection>

  <SourceList sources={sources} />
</ContentLayout>
