---
import ClaimCard from "../components/ClaimCard.astro";
import Icon from "../components/Icon.astro";
import SourceLink from "../components/SourceLink.astro";
import SourceList from "../components/SourceList.astro";
import StatusBadge from "../components/StatusBadge.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../../site.config.mjs";

const sources = [
  {
    label: "Organization profile",
    href: "https://github.com/open-proofline/.github/blob/main/profile/README.md",
  },
  {
    label: "Server README",
    href: "https://github.com/open-proofline/server/blob/develop/README.md",
  },
  {
    label: "Web-client README",
    href: "https://github.com/open-proofline/web-client/blob/develop/README.md",
  },
  {
    label: "Server security policy",
    href: "https://github.com/open-proofline/server/blob/develop/SECURITY.md",
  },
];
---

<BaseLayout
  title="Proofline"
  description="Experimental encrypted incident-capture infrastructure. Clients keep decryption control. Proofline is not an emergency service."
>
  <section
    class="relative isolate overflow-hidden border-b border-proofline-border bg-[linear-gradient(135deg,#07030d_0%,#12051f_48%,#241142_100%)]"
  >
    <img
      src="/proofline-p-mark.svg"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute right-[-5rem] top-36 size-72 opacity-[0.06] lg:hidden"
    />
    <div
      class="mx-auto grid min-h-svh max-w-6xl gap-10 px-4 pb-12 pt-32 sm:px-6 sm:pb-16 sm:pt-36 lg:grid-cols-[minmax(0,1fr)_23rem] lg:items-center lg:pb-20 lg:pt-36"
    >
      <div class="relative z-10 min-w-0">
        <div class="flex flex-wrap gap-2">
          <StatusBadge tone="warning">Experimental</StatusBadge>
          <StatusBadge tone="info">Pre-v1</StatusBadge>
          <StatusBadge tone="danger">Not an emergency service</StatusBadge>
        </div>
        <p class="mt-7 text-sm font-medium text-proofline-accent-cyan">
          Public-interest privacy and safety infrastructure
        </p>
        <h1
          class="mt-4 max-w-4xl text-5xl font-semibold leading-none tracking-normal text-proofline-text sm:text-7xl lg:text-[5.5rem]"
        >
          Record the truth. Keep the keys.
        </h1>
        <p
          class="mt-6 max-w-2xl text-lg leading-7 text-proofline-text-secondary sm:text-xl sm:leading-8"
        >
          Proofline helps preserve end-to-end encrypted evidence as events
          unfold, while giving trusted contacts controlled access when it
          matters.
        </p>
        <p class="mt-4 max-w-2xl text-sm leading-6 text-proofline-text-muted">
          Proofline is not production-ready, not emergency dispatch, and not a
          guaranteed real-time safety system.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-2">
          <a
            href="/services/"
            class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-proofline-border-strong bg-proofline-primary px-4 py-3 text-sm font-semibold text-proofline-primary-text shadow-lg shadow-proofline-bg-deep/30 transition-colors hover:bg-proofline-primary-hover focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
          >
            <Icon name="globe" class="size-4" />
            <span>Community Services</span>
          </a>
          <a
            href="/about/"
            class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-proofline-border-strong bg-proofline-surface-strong/90 px-4 py-3 text-sm font-semibold text-proofline-text shadow-lg shadow-proofline-bg-deep/30 transition-colors hover:bg-proofline-border focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
          >
            <Icon name="info" class="size-4" />
            <span>About</span>
          </a>
          <a
            href={site.githubOrg}
            aria-label="Open Proofline on GitHub"
            class="inline-flex min-h-12 items-center justify-center gap-2 rounded-md border border-proofline-border bg-proofline-bg-deep/60 px-4 py-3 text-sm font-semibold text-proofline-text transition-colors hover:bg-proofline-surface-elevated focus:outline-2 focus:outline-offset-2 focus:outline-proofline-focus"
          >
            <Icon name="github" class="size-[17px]" />
            <span>GitHub</span>
          </a>
        </div>
      </div>

      <div
        class="relative mx-auto grid min-h-80 w-full max-w-sm place-items-center lg:min-h-[34rem]"
        aria-hidden="true"
      >
        <div
          class="absolute inset-8 rounded-[999px] border border-proofline-border/70 bg-proofline-primary/5 shadow-[0_0_90px_rgba(167,139,250,0.24)]"
        >
        </div>
        <img
          src="/proofline-p-mark.svg"
          alt=""
          class="relative size-56 opacity-95 drop-shadow-[0_0_34px_rgba(196,181,253,0.24)] sm:size-64"
        />
      </div>
    </div>
  </section>

  <section
    class="border-b border-proofline-border bg-proofline-bg px-4 py-12 sm:px-6 lg:py-16"
  >
    <div class="mx-auto max-w-6xl">
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-proofline-accent-cyan">
          Community services
        </p>
        <h2
          class="mt-3 max-w-3xl text-3xl font-semibold tracking-normal text-proofline-text sm:text-5xl"
        >
          Separate privacy-respecting tools for the public web.
        </h2>
        <p
          class="mt-4 max-w-3xl text-base leading-7 text-proofline-text-secondary sm:text-lg"
        >
          Community services are planned best-effort open-source tools operated
          separately from Proofline Server. They are not part of Proofline's
          safety, evidence, account, or emergency workflows.
        </p>
        <p class="mt-5">
          <SourceLink href="/services/">Review community services</SourceLink>
        </p>
      </div>
      <div
        class="mt-6 grid gap-4 text-sm leading-6 text-proofline-text-secondary md:grid-cols-2"
      >
        <div
          class="rounded-lg border border-proofline-border bg-proofline-surface/70 p-4"
        >
          <p class="font-semibold text-proofline-text">Best effort</p>
          <p class="mt-1">
            Services may change, pause, move, or go offline while the project is
            early.
          </p>
        </div>
        <div
          class="rounded-lg border border-proofline-border bg-proofline-surface/70 p-4"
        >
          <p class="font-semibold text-proofline-text">Separate system</p>
          <p class="mt-1">
            They do not store Proofline evidence, encrypted chunks, account
            data, or safety-context records.
          </p>
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto grid max-w-6xl gap-6 px-4 py-12 sm:px-6 lg:py-16">
    <section>
      <div class="max-w-3xl">
        <p class="text-sm font-medium text-proofline-accent-cyan">
          Current boundaries
        </p>
        <h2
          class="mt-3 text-2xl font-semibold tracking-normal text-proofline-text sm:text-4xl"
        >
          Early infrastructure with explicit limits.
        </h2>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        <ClaimCard label="Current" tone="success" title="Experimental backend">
          The active Go server provides authenticated API routes, encrypted
          chunk storage, owner and trusted-contact metadata, wrapped-key
          metadata, quotas, rate limits, and experimental relay primitives.
        </ClaimCard>
        <ClaimCard label="Current" tone="success" title="Web-client prototype">
          The React web-client prototype shows account and incident-review
          surfaces in mock mode or where live API contracts are confirmed.
        </ClaimCard>
        <ClaimCard label="Open source" tone="info" title="Source-first project">
          Current repositories are
          <SourceLink href={site.repositories.server}>server</SourceLink> and
          <SourceLink href={site.repositories.webClient}>web-client</SourceLink
          >. Native clients and protocol work are planned separately.
        </ClaimCard>
        <ClaimCard label="Safety" tone="warning" title="No response center">
          Proofline does not contact emergency services, guarantee real-time
          review, or replace user and trusted-contact judgment.
        </ClaimCard>
        <ClaimCard label="Not yet" tone="danger" title="Production service">
          Production mobile clients, hosted subscriptions, trusted-contact
          notifications, browser decryption, key escrow, and playable media
          export are not implemented.
        </ClaimCard>
        <ClaimCard label="Funding" tone="warning" title="No paid access today">
          There is no company, response center, support department,
          donation-gated account access, checkout flow, or active paid account
          creation today.
        </ClaimCard>
      </div>
    </section>

    <SourceList sources={sources} />
  </div>
</BaseLayout>
